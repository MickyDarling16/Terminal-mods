{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"blocks": [
		{
			"alignment": "left",
			"segments": [
        {
          "_comment": "Operating System Icon Segment",
          "foreground": "#0b539f",
          "properties": {
            "windows": "\ue62a "
          },
          "style": "powerline",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}",
          "type": "os"
        },
				{
					"_comment": "Administrator Segment",
					"foreground": "#E06C75",
					"style": "plain",
					"template": "<#ffffff>as</> Admin ",
					"type": "root"
				},
				{
					"_comment": "Folder Name Segment",
					"foreground": "#55B9C4",
					"properties": {
						"style": "folder"
					},
					"style": "plain",
					"template": "<#ffffff>in</> {{ .Path }} ",
					"type": "path"
				},
				{
					"_comment": "Git Information Segment",
					"foreground": "#C678DD",
					"properties": {
						"fetch_status": true
					},
					"style": "plain",
					"template": "<#ffffff>on</> {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} ",
					"type": "git"
				},
				{
          "_comment": "On Error Icon Segment",
					"foreground": "#C94A16",
					"style": "plain",
					"template": "x ",
					"type": "status"
				}
			],
			"type": "prompt"
		},
		{
			"_comment": "Newline Segment. Right below the first line of prompt`",
			"alignment": "left",
			"newline": true,
			"segments": [
				{
					"foreground": "#63F08C",
					"style": "plain",
					"template": "➜  ",
					"type": "text"
				}
			],
			"type": "prompt"
		}
	],
	"version": 3
}